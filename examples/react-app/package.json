{
  "name": "@yoo-digital/example-react-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "pnpm lint:ts && pnpm lint:css",
    "lint:ts": "eslint ./src",
    "lint:css": "stylelint './src/**/*.css'",
    "start": "vite preview",
    "format": "prettier --write ."
  },
  "dependencies": {
    "react": "~19.2.0",
    "react-dom": "~19.2.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.0",
    "@types/react-dom": "~19.2.0",
    "@typescript-eslint/parser": "~8.58.0",
    "@vitejs/plugin-react": "~6.0.1",
    "@yoo-digital/eslint-config-react": "workspace:~",
    "@yoo-digital/prettier": "workspace:~",
    "@yoo-digital/stylelint-config-css": "workspace:~",
    "eslint": "~9.39.0",
    "eslint-import-resolver-typescript": "~4.4.4",
    "eslint-plugin-react-hooks": "~7.0.0",
    "eslint-plugin-react-refresh": "~0.5.0",
    "globals": "~16.3.0",
    "prettier": "~3.6.2",
    "stylelint": "~17.8.0",
    "typescript": "~5.9.2",
    "vite": "~8.0.8"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
